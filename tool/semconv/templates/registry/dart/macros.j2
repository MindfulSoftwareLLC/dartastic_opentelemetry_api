{#- camelCase Dart identifier for a dotted/underscored id, with Dart
    reserved words escaped via the reserved_words text map. -#}
{% macro ident(id) -%}
{{ id | camel_case | map_text("reserved_words") }}
{%- endmacro %}

{#- PascalCase Dart type name for a namespace root, with dart:core/io/
    Flutter clashes renamed via the enum_name_overrides text map. -#}
{% macro type_name(root) -%}
{{ root | pascal_case | map_text("enum_name_overrides") }}
{%- endmacro %}

{#- Single-line, single-quote-safe, interpolation-safe Dart string body. -#}
{% macro dart_str(text) -%}
{{ text | replace("\\", "\\\\") | replace("'", "\\'") | replace("$", "\\$") | replace("\n", " ") | replace("\r", "") }}
{%- endmacro %}

{#- @Deprecated message from a resolved `deprecated` block. The resolver
    auto-fills `note` (e.g. "Replaced by `x`.") when reason is `renamed`,
    so prefer it and only fall back to `renamed_to`. -#}
{% macro deprecated_message(dep) -%}
{%- if dep.note is defined and dep.note %}{{ dart_str(dep.note | trim) }}
{%- elif dep.renamed_to is defined and dep.renamed_to %}Replaced by `{{ dep.renamed_to }}`.
{%- else %}Deprecated in the OpenTelemetry semantic conventions.
{%- endif -%}
{%- endmacro %}

{#- One "Examples: ..." doc line, or an empty list when none. -#}
{% macro _examples_line(item) -%}
{%- if item.examples is defined and item.examples is not none -%}
{%- set exlist = item.examples if (item.examples is sequence and item.examples is not string) else [item.examples] -%}
{%- if exlist | length > 0 -%}
Examples: `{{ exlist | join(", ") | replace("\n", " ") | replace("\r", "") | replace("`", "'") }}`
{%- endif -%}
{%- endif -%}
{%- endmacro %}

{#- Doc block (brief, examples, stability) for attributes / members /
    metrics / events / entities, emitted at 2-space member indentation.
    Emits complete lines (each ending in a newline) or nothing. -#}
{% macro doc(item) -%}
{%- set brief = (item.brief | trim) if (item.brief is defined and item.brief) else "" -%}
{%- set ex = _examples_line(item) | trim -%}
{%- set stab = ("Stability: " ~ item.stability) if (item.stability is defined and item.stability and item.stability != "stable") else "" -%}
{%- set parts = ([brief] if brief else []) + ([ex] if ex else []) + ([stab] if stab else []) -%}
{% if parts | length > 0 %}
{{ "  " }}{{ parts | join("\n\n") | comment(indent=2) }}
{% endif %}
{%- endmacro %}

{#- @Deprecated annotation line at member indentation (or nothing). -#}
{% macro deprecated_annotation(item) -%}
{% if item.deprecated is defined and item.deprecated %}
{{ "  " }}@Deprecated('{{ deprecated_message(item.deprecated) }}')
{% endif %}
{%- endmacro %}

{#- Type-level @Deprecated annotation at column 0 (or nothing). -#}
{% macro deprecated_annotation_top(item) -%}
