{%- import 'macros.j2' as m -%}
{{ m.file_header() }}

/// Semantic-convention event names for the `{{ ctx.root_namespace }}`
/// namespace.
library;

import '../../semantics_base.dart';

/// `{{ ctx.root_namespace }}` event names from the OpenTelemetry semantic
/// conventions.
enum {{ ctx.root_namespace | pascal_case }}Event implements OTelEvent {
{% for event in ctx.events %}
{{ m.doc(event) }}{{ m.deprecated_annotation(event) }}  {{ m.ident(event.name) }}('{{ event.name }}'){{ "," if not loop.last else ";" }}
{% endfor %}

  @override
  final String name;

  const {{ ctx.root_namespace | pascal_case }}Event(this.name);

  @override
  String toString() => name;
}
